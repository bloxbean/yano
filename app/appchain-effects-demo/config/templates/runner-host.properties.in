demo.chain-id=@CHAIN_ID@
demo.yano.urls=http://127.0.0.1:@HTTP0@/api/v1,http://127.0.0.1:@HTTP1@/api/v1,http://127.0.0.1:@HTTP2@/api/v1
demo.yano.member-keys=@MEMBER_KEYS@
demo.yano.threshold=2
demo.sample-file=@SAMPLE_FILE@
demo.report-directory=@REPORT_DIRECTORY@
demo.evidence-id=inspection-2026-0716
s3.endpoint=@S3_ENDPOINT@
s3.region=us-east-1
s3.access-key-file=@MINIO_RUNNER_ACCESS_FILE@
s3.secret-key-file=@MINIO_RUNNER_SECRET_FILE@
s3.source-bucket=evidence-staging
s3.source-prefix=incoming/v1
s3.destination-bucket=evidence-archive
s3.destination-prefix=verified/v1
s3.target=archive
s3.target-id=@S3_TARGET_ID@
s3.encryption-policy-id=demo-none-v1
s3.retention-policy-id=none-v1
s3.path-style=true
ipfs.api-url=@IPFS_API_URL@
ipfs.target=local
ipfs.target-id=@IPFS_TARGET_ID@
ipfs.replication-policy=demo-single
kafka.bootstrap-servers=@KAFKA_BOOTSTRAP_SERVERS@
kafka.target=primary
kafka.target-id=@KAFKA_TARGET_ID@
kafka.topic-alias=evidence-ready
kafka.physical-topic=evidence.available.v1
scenario.timeout-seconds=@TIMEOUT_SECONDS@
scenario.poll-interval-millis=@POLL_INTERVAL_MILLIS@
scenario.require-anchor=@REQUIRE_ANCHOR@
