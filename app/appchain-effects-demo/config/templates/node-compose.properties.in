# Generated by demo.sh. This file is private because node 0 contains connector credentials.
config_ordinal=275
quarkus.http.host=0.0.0.0
quarkus.http.port=7070
yano.server.port=13337
yano.storage.path=/app/chainstate
yano.genesis.shelley-genesis-file=/run/demo/shelley-genesis.json
@GENESIS_TIMESTAMP_SETTING@
yano.relay.connection.source-port-reuse=false
yano.relay.connection.max-connections-per-ip=500
yano.app-chain.api.auth.enabled=false
yano.app-chain.api.keys=@API_KEY@
yaci.plugins.enabled=true
yaci.plugins.directory=/app/plugins
yaci.plugins.allow-list=com.bloxbean.cardano.yano.appchain.kafka,com.bloxbean.cardano.yano.appchain.ipfs,com.bloxbean.cardano.yano.appchain.objectstore.s3,com.bloxbean.cardano.yano.appchain.evidence-registry,com.bloxbean.cardano.yano.appchain.stdlib,com.bloxbean.cardano.yano.appchain.evidence-profile

yano.app-chain.chains[0].chain-id=@CHAIN_ID@
yano.app-chain.chains[0].state-machine=@STATE_MACHINE@
yano.app-chain.chains[0].signing-key=@SIGNING_KEY@
yano.app-chain.chains[0].members=@MEMBER_KEYS@
yano.app-chain.chains[0].threshold=2
yano.app-chain.chains[0].peers=@APP_PEERS@
yano.app-chain.chains[0].sequencer.proposer=@PROPOSER_KEY@
yano.app-chain.chains[0].block.interval-ms=1000
yano.app-chain.chains[0].block.max-messages=64
yano.app-chain.chains[0].effects.enabled=true
yano.app-chain.chains[0].effects.max-per-block=128
yano.app-chain.chains[0].effects.max-payload-bytes=16384
yano.app-chain.chains[0].effects.max-expiry-blocks=100000
yano.app-chain.chains[0].effects.result-window-blocks=100000
yano.app-chain.chains[0].effects.default-gate=app-final
yano.app-chain.chains[0].effects.outcome-commitment=per-effect
yano.app-chain.chains[0].effects.result.signers=@RESULT_SIGNERS@
yano.app-chain.chains[0].effects.metrics.types=object.put,ipfs.pin,kafka.publish
yano.app-chain.chains[0].machines.evidence-registry.storage-gate=@STORAGE_GATE@
yano.app-chain.chains[0].machines.evidence-registry.storage-expiry-blocks=0
yano.app-chain.chains[0].machines.evidence-registry.notification-expiry-blocks=0
@MACHINE_PRESET_SETTING@
yano.app-chain.chains[0].machines.composite.evidence-capacity-per-block=@EVIDENCE_CAPACITY_PER_BLOCK@
yano.app-chain.chains[0].membership.mode=governed
yano.app-chain.chains[0].machines.composite.profile-mode=governed
@DIRECT_RESULT_ACTIVATION_SETTING@
@NODE_SETTINGS@
