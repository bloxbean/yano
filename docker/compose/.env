YANO_IMAGE_TAG=latest
INSTANCE_NAME=default

YANO_IMAGE=bloxbean/yano
YANO_IMAGE_FLAVOR=jvm

# Comma-separated Quarkus profile list. The launcher uses the first profile as the network.
YANO_PROFILE=preprod
YANO_HTTP_PORT=7070
YANO_N2N_PORT=13337
YANO_UID=1000
YANO_GID=1000
# Optional host path for chainstate. Leave unset for network-specific defaults.
# YANO_CHAINSTATE_PATH=../chainstate-preprod

# JVM image only. Uncomment and tune when you want explicit JVM heap settings.
# JAVA_OPTS=-Xms1g -Xmx4g
YANO_EXTRA_ARGS=
