{
  "schemaVersion": 1,
  "id": "com.example.appchain.counter",
  "version": "0.1.0",
  "yanoApi": { "min": 1, "max": 1, "minLevel": 1 },
  "dependencies": [],
  "contributions": [
    {
      "kind": "app-state-machine",
      "name": "counter",
      "provider": "com.example.appchain.CounterStateMachineProvider"
    },
    {
      "kind": "domain-api",
