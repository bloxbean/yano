; E7.2 BBS-signed credential body (ADR app-layer/006).
; Stored on-chain via the credential-registry machine, which admits it only if
; the issuer's BBS signature verifies against a configured issuer key. A holder
; later derives a selective-disclosure presentation (BbsPresentationCodec) from
; the same attributes+signature, verified client-side against the issuer key and
; the anchored record. Issuers are configured, decoupled from chain membership.

bbs-credential-body = [
    issuer-id     : tstr,       ; matches a pinned yano.app-chain.zk.bbs.issuers[i].id
    credential-id : tstr,       ; registry key
    signature     : bstr,       ; CFRG BBS signature octets
    header        : bstr,       ; BBS signature header (may be empty)
    attributes    : [* bstr],   ; the signed attribute set (index order is stable)
]
