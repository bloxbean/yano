{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yano.dev/schema/appchain-component-catalog/v1alpha1",
  "title": "Yano custom app-chain component product catalog",
  "type": "object",
  "required": ["schemaVersion", "catalogId", "bundleId", "bundleVersion", "artifact", "capabilities"],
  "properties": {
    "schemaVersion": {"const": "v1alpha1"},
    "catalogId": {"$ref": "#/$defs/id"},
    "bundleId": {"$ref": "#/$defs/id"},
    "bundleVersion": {"type": "string", "minLength": 1, "maxLength": 128},
    "artifact": {"$ref": "#/$defs/artifact"},
    "capabilities": {
      "type": "array", "minItems": 1, "maxItems": 64,
      "items": {"$ref": "#/$defs/capability"}
    }
  },
  "additionalProperties": false,
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9.-]{0,127}$"},
    "capabilityId": {"type": "string", "pattern": "^[a-z][a-z0-9.-]*(?::[a-z][a-z0-9.-]*)?$"},
    "stringList": {"type": "array", "maxItems": 128, "items": {"type": "string", "maxLength": 512}, "uniqueItems": true},
    "artifact": {
      "type": "object",
      "required": ["id", "availability", "bundleId", "nativePosture", "runtimeTypes", "deploymentTargets"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "availability": {"enum": ["REFERENCE", "EXPERIMENTAL"]},
        "bundleId": {"$ref": "#/$defs/id"},
        "nativePosture": {"const": "unsupported"},
        "runtimeTypes": {"type": "array", "prefixItems": [{"const": "jvm"}], "items": false, "minItems": 1, "maxItems": 1},
        "deploymentTargets": {"type": "array", "minItems": 1, "maxItems": 2, "items": {"enum": ["host", "docker-compose"]}, "uniqueItems": true}
      },
      "additionalProperties": false
    },
    "capability": {
      "type": "object",
      "required": ["id", "name", "category", "availability", "maturity", "scope", "selectable", "trustStatement", "description", "provides", "requires", "implies", "conflicts", "runtimeTypes", "deploymentTargets", "artifacts", "nativePosture", "externalPrerequisites", "bootstrapRequirements", "nonSecretAnswers", "secretReferences", "properties", "documentation", "acceptanceScenario"],
      "properties": {
        "id": {"$ref": "#/$defs/capabilityId"},
        "name": {"type": "string", "minLength": 1, "maxLength": 128},
        "category": {"type": "string", "minLength": 1, "maxLength": 64},
        "availability": {"enum": ["REFERENCE", "EXPERIMENTAL"]},
        "maturity": {"enum": ["preview", "experimental"]},
        "scope": {"enum": ["chain", "node"]},
        "selectable": {"const": true},
        "trustStatement": {"type": "string", "minLength": 1, "maxLength": 1024},
        "description": {"type": "string", "minLength": 1, "maxLength": 1024},
        "provides": {"$ref": "#/$defs/stringList"},
        "requires": {"$ref": "#/$defs/stringList"},
        "implies": {"$ref": "#/$defs/stringList"},
        "conflicts": {"$ref": "#/$defs/stringList"},
        "runtimeTypes": {"type": "array", "prefixItems": [{"const": "jvm"}], "items": false, "minItems": 1, "maxItems": 1},
        "deploymentTargets": {"type": "array", "minItems": 1, "maxItems": 2, "items": {"enum": ["host", "docker-compose"]}, "uniqueItems": true},
        "artifacts": {"type": "array", "minItems": 1, "maxItems": 1, "items": {"$ref": "#/$defs/id"}},
        "nativePosture": {"const": "unsupported"},
        "externalPrerequisites": {"$ref": "#/$defs/stringList"},
        "bootstrapRequirements": {"$ref": "#/$defs/stringList"},
        "nonSecretAnswers": {"$ref": "#/$defs/stringList"},
        "secretReferences": {"type": "object", "maxProperties": 32, "additionalProperties": {"type": "string", "maxLength": 512}},
        "properties": {"type": "object", "maxProperties": 128, "additionalProperties": {"type": "string", "maxLength": 4096}},
        "documentation": {"type": "string", "minLength": 1, "maxLength": 512},
        "acceptanceScenario": {"type": "string", "minLength": 1, "maxLength": 128}
      },
      "additionalProperties": false
    }
  }
}
