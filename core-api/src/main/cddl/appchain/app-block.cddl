; =============================================================================
; Yano App-Chain: App Block and Finality Certificate (v1)
; =============================================================================
; One finalized app-chain block: a batch of verified app messages given a
; total order by the sequencer, binding the post-state commitment root.
; Canonical CBOR — the same bytes are gossiped (proposals on system topic
; "~consensus/propose"), stored in the app ledger, and hashed.
;
; block-hash = blake2b-256( cbor(app-block-header) )
;   The header binds the full message list via messages-root and the whole
;   history via prev-hash; the certificate is NOT part of the hash (it signs
;   the hash).
;
; messages-root: binary merkle tree (blake2b-256 over left||right) built over
;   the ordered message-ids; empty list -> 32 zero bytes; odd level width ->
;   last node duplicated.
;
; state-root: Merkle Patricia Forestry root (Aiken-compatible, blake2b-256)
;   AFTER applying this block — followers re-execute the block and must
;   reproduce it byte-for-byte before voting.
;
; Consensus messages ride the ordinary authenticated app-message envelope
; (see app-message-envelope.cddl) on reserved system topics:
;   "~consensus/propose" body = app-block (cert empty)
;   "~consensus/vote"    body = vote
;   "~consensus/cert"    body = cert-notice
; =============================================================================

app-block = [
    version       : uint,             ; block format version, currently 1
    chain-id      : tstr,
    height        : uint,             ; global per-chain sequence, first block = 1
    prev-hash     : bstr .size 32,    ; 32 zero bytes at height 1
    l1-slot       : uint,             ; stable L1 reference slot (0 = unavailable)
    l1-block-hash : bstr,             ; stable L1 reference block hash ("" = unavailable)
    timestamp     : uint,             ; proposer wall clock, unix millis
    messages-root : bstr .size 32,
    state-root    : bstr .size 32,
    messages      : [ *app-message ], ; ordered full envelopes
    proposer      : bstr .size 32,    ; proposer's Ed25519 public key
    cert          : finality-cert
]

app-block-header = [
    version, chain-id, height, prev-hash, l1-slot, l1-block-hash,
    timestamp, messages-root, state-root
]

finality-cert = [
    scheme     : uint,                ; 0 = Ed25519 threshold signatures over block-hash
    signatures : [ *cert-signature ]
]

cert-signature = [
    signer    : bstr .size 32,        ; member Ed25519 public key
    signature : bstr                  ; Ed25519 signature over block-hash
]

vote = [
    height     : uint,
    block-hash : bstr .size 32,
    signature  : bstr                 ; voter's Ed25519 signature over block-hash
]

cert-notice = [
    height     : uint,
    block-hash : bstr .size 32,
    cert       : bstr                 ; cbor(finality-cert)
]

; app-message: see yaci core/src/main/cddl/appmsg/app-message-envelope.cddl
