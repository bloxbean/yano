; =============================================================================
; Yano App-Chain: L1 observation wire format (v1) — ADR app-layer/008.4 §3.1
; =============================================================================
; Body of a `~l1/<observer-id>` message: a pointer + claim. The pointer names
; an L1 transaction; the claim is observer-specific CBOR that every member
; recomputes from its OWN L1 view. Follower verification is consensus-critical:
; a proposed observation whose claim differs from the follower's own
; recomputation rejects the proposal (fail-closed); observations ahead of the
; follower's L1 view defer-retry; observations older than the verification
; window are accepted (the certified chain vouches — same semantics as l1-refs).

l1-observation = [
    version     : 1,
    observer-id : tstr,            ; configured instance id (= topic suffix)
    tx-hash     : bstr .size 32,   ; L1 transaction the claim points at
    slot        : uint,            ; L1 slot of the containing block
    block-hash  : bstr .size 32,   ; L1 block hash at that slot
    claim       : bstr,            ; observer-specific claim (CBOR)
]

; Built-in claim payloads:
;
; metadata-label observer (watch tx metadata label N):
;   claim = the raw CBOR bytes of the watched label's metadata value
;
; address-deposit observer (watch payments to an address):
;   claim = [ address : tstr, lovelace : uint ]   ; total paid to address in tx
